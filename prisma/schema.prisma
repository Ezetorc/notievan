generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

model Article {
  id           String   @id @default(cuid())
  title        String
  subtitle     String
  description  String
  content      String   @db.Text()
  createdAt    DateTime @default(now())
  authorId     String
  thumbnailUrl String
  thumbnailAlt String

  author User @relation(fields: [authorId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  role      Role     @default(USER)

  articles Article[]
}

enum Role {
  USER
  AUTHOR
  ADMIN
}
