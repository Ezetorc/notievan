---
import type { Article as ArticleData } from "@prisma/client";
import Article from "./Article.astro";
import H3 from "./H3.astro";
import H4 from "./H4.astro";
import H5 from "./H5.astro";
import { UsersService } from "../services/users.service";

interface Props {
  article: ArticleData;
}

const { article } = Astro.props;

const authorName = await UsersService.getNameOfUserWithId(article?.authorId);
---

<Article id={article.id} class="flex flex-col gap-y-4 w-full">
  <img
    loading="eager"
    src={article.thumbnailUrl}
    alt={article.thumbnailAlt}
    class="min-h-[100px] mobile:max-h-[200px] desktop:max-h-[400px] h-full aspect-[9/16] bg-gray-200 w-full object-cover"
  />

  <div class="flex flex-col gap-y-2 w-full">
    <H4 class="text-3xl break-words">{article.subtitle}</H4>
    <H3 class="text-3xl break-words">{article.title}</H3>
    <p class="text-gray-900 text-[18px] break-words">{article.description}</p>
    <H5 class="mt-2 break-words">{authorName}</H5>
  </div>
</Article>
