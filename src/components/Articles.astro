---
import MainArticle from "./MainArticle.astro";
import SecondaryArticle from "./SecondaryArticle.astro";
import TerciaryArticle from "./TerciaryArticle.astro";
import { ArticlesService } from "../services/articles.service";

const articles = await ArticlesService.getMostRecent(4);
---

<main class="w-full h-[700px] grid grid-cols-12 grid-rows-8 gap-2">
  <MainArticle article={articles[0]} class="col-span-6 row-span-8" />
  <SecondaryArticle
    article={articles[1]}
    class="col-span-6 row-span-3 col-start-7"
  />
  <TerciaryArticle
    article={articles[2]}
    class="col-span-3 row-span-5 col-start-10 row-start-4"
  />
  <TerciaryArticle
    article={articles[3]}
    class="col-span-3 row-span-5 col-start-7 row-start-4"
  />
</main>
