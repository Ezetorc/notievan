---
import type { Article as ArticleData } from "@prisma/client";
import Article from "./Article.astro";
import H3 from "./H3.astro";
import H4 from "./H4.astro";
import H5 from "./H5.astro";
import LoadingArticle from "./LoadingArticle.astro";
import { UsersService } from "../services/users.service";

interface Props {
  class?: string;
  article?: ArticleData;
}

const { class: extraClass = "", article } = Astro.props;

const authorName = await UsersService.getNameOfUserWithId(article?.authorId);
---

<>
  {
    article ? (
      <Article
        id={article.id}
        class={`grid grid-cols-[1fr_1fr] gap-x-5 h-full ${extraClass}`}
      >
        <img
          loading="eager"
          src={article.thumbnailUrl}
          alt={article.thumbnailAlt}
          class="h-[clamp(100px,100%,300px)] w-full object-cover"
        />

        <div class="flex flex-col justify-between">
          <div class="flex flex-col">
            <H4 class="text-[20px]">{article.subtitle}</H4>
            <H3 class="text-[20px]">{article.title}</H3>
            <p class="text-gray-900 text-[18px]">{article.description}</p>
          </div>

          <H5>{authorName}</H5>
        </div>
      </Article>
    ) : (
      <LoadingArticle
        class={`grid grid-cols-[1fr_1fr] gap-x-5 h-full ${extraClass}`}
      />
    )
  }
</>
