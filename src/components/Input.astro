---
const { id } = Astro.props;
---

<div>
  <label for={id} class="block text-[24px] text-gray-700">
    <slot />
  </label>

  <input
    {...Astro.props}
    name={id}
    class="w-full p-4 placeholder:text-[20px] mt-1 border border-gray-300 rounded-md shadow-sm text-gray-900 focus:ring-gray-800 focus:border-gray-800 sm:text-base"
  />
</div>
