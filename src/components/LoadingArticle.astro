---
interface Props {
  class?: string;
}

const { class: extraClass = "" } = Astro.props;
---

<article class={`flex flex-col gap-y-4 p-4 rounded-lg border border-gray-200 ${extraClass}`}>
  <div class="w-full h-48 bg-gray-300 rounded-lg animate-pulse"></div>

  <div class="flex flex-col gap-y-2 mt-2">
    <div class="h-4 bg-gray-300 rounded w-1/3 animate-pulse"></div>
    <div class="h-6 bg-gray-300 rounded w-2/3 animate-pulse"></div>
    <div class="h-4 bg-gray-300 rounded w-full animate-pulse"></div>
    <div class="h-4 bg-gray-300 rounded w-5/6 animate-pulse"></div>
  </div>
</article>
