---
import type { Article as ArticleData } from "../models/article.model";
import Article from "./Article.astro";
import H3 from "./H3.astro";
import H4 from "./H4.astro";
import H5 from "./H5.astro";
import LoadingArticle from "./LoadingArticle.astro";

interface Props {
  class?: string;
  article?: ArticleData;
}

const { class: extraClass = "", article } = Astro.props;
---

<>
  {
    article ? (
      <Article id={article.id} class={`flex flex-col gap-y-6 ${extraClass}`}>
        <img
          loading="eager"
          src={article.thumbnail.url}
          alt={article.thumbnail.alt}
          class="h-[clamp(100px,100%,200px)] w-full object-cover"
        />

        <div>
          <div class="flex flex-col gap-y-2">
            <H4 class="text-[20px]">{article.subtitle}</H4>
            <H3 class="text-[20px]">{article.title}</H3>
          </div>

          <H5>{article.authorId}</H5>
        </div>
      </Article>
    ) : (
      <LoadingArticle class={`flex flex-col gap-y-6 ${extraClass}`} />
    )
  }
</>
