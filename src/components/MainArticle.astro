---
import { Image } from "astro:assets";

interface Props {
  class?: string;
  image: ImageMetadata;
  alt: string;
  title: string;
  subtitle: string;
  author: string;
}

const {
  class: extraClass = "",
  image,
  alt,
  title,
  subtitle,
  author,
} = Astro.props;
---

<a href={`/articulos/${title}`} class={`w-full h-full flex flex-col overflow-hidden ${extraClass}`}>
  <div class="h-2/4 w-full overflow-hidden">
    <Image loading="eager" src={image} alt={alt} class="w-full h-full object-cover" />
  </div>

  <div class="mt-7 flex flex-col justify-center gap-y-2 pr-4">
    <h4 class="text-red-600 font-playfair-semibold text-2xl">{subtitle}</h4>
    <h3 class="text-black font-playfair-bold text-3xl">{title}</h3>
    <h5 class="text-gray-700 text-[20px]">{author}</h5>
  </div>
</a>
