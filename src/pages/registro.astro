---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Input from "../components/Input.astro";
import AuthSwipeLink from "../components/AuthSwipeLink.astro";
---

<Layout>
  <Hero title="Registro" description="Creá tu cuenta" />

  <section class="w-[clamp(300px,100%,800px)] mb-[10vw]">
    <form id="form" class="flex w-full flex-col gap-y-6">
      <Input id="name" name="name" placeholder="Juan Pérez" type="text" required
        >Nombre completo</Input
      >
      <Input
        name="email"
        placeholder="juanPEREZ@email.com"
        type="email"
        required>Correo electrónico</Input
      >
      <Input
        name="password"
        placeholder="juanPEREZ123!"
        type="password"
        minLength="6"
        maxLength="30"
        required>Contraseña</Input
      >

      <button
        type="submit"
        class="w-full cursor-pointer mt-6 bg-brand-orange text-white py-3 px-6 rounded-md shadow serif clickable transition-colors"
      >
        Crear cuenta
      </button>

      <p id="message" class="text-brand-red mt-2 text-2xl hidden"></p>
    </form>

    <AuthSwipeLink>
      ¿Tenés cuenta?
      <a href="/sesion" class="underline cursor-pointer hover:text-gray-900"
        >Iniciá sesión</a
      >
    </AuthSwipeLink>
  </section>
</Layout>

<script>
  import { AuthService } from "../services/auth.service";
  import { SessionService } from "../services/session.service";

  function render() {
    const $form = document.getElementById("form") as HTMLFormElement;
    const $message = document.getElementById("message");

    if (!$form || !$message) return;

    $form.addEventListener("submit", async (event) => {
      event.preventDefault();
      $message.classList.add("hidden");

      const formData = new FormData($form);
      const email = String(formData.get("email"));
      const password = String(formData.get("password"));
      const name = String(formData.get("name"));

      if (!email || !password || !name) return;

      try {
        const data = await AuthService.register({ email, password, name });

        SessionService.value = data;
        window.location.href = "/";
      } catch (error) {
        if (error instanceof Error) {
          $message.textContent = error.message;
          $message.classList.remove("hidden");
        }
      }
    });
  }

  render();
</script>
